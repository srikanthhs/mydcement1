# ════════════════════════════════════════════
# MYL Cement Tracker – Environment Variables
# Copy to .env and fill in your values
# ════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=3000

# JWT – change this to a long random secret in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRY=12h

# CORS – frontend origin (dev: same port, prod: your domain)
CORS_ORIGIN=http://localhost:3000

# Firebase – Option A: paste full service account JSON (inline, single line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Firebase – Option B: path to service account key file
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Firebase – Project ID (required for emulator mode)
FIREBASE_PROJECT_ID=mydcement

# Firestore Emulator (development – leave blank for real Firebase)
# FIRESTORE_EMULATOR_HOST=localhost:8080
